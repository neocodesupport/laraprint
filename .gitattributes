# Normalize line endings
* text=auto eol=lf

# Force PHP/JSON/Markdown to LF
*.php   text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.xml   text eol=lf

# Files excluded from the Composer/Git archive (dist) — keep installs lean
/.github            export-ignore
/tests              export-ignore
/docs               export-ignore
.gitattributes      export-ignore
.gitignore          export-ignore
.editorconfig       export-ignore
phpunit.xml         export-ignore
CHANGELOG.md        export-ignore
README.fr.md        export-ignore
